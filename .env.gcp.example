# ─────────────────────────────────────────────────────────────────────────────
# GCP Deployment Environment Variables
# Copy this file to .env.gcp and fill in your values before running:
#   docker compose -f docker-compose.yml -f docker-compose.gcp.yml --env-file .env.gcp up -d
# ─────────────────────────────────────────────────────────────────────────────

# ── GCP Project ───────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# ── Google Cloud Storage ──────────────────────────────────────────────────────
# The GCS bucket used as the data lake (replaces fake-gcs-server from local dev).
# Create with: gsutil mb -l us-central1 gs://your-pipeline-datalake
STORAGE_BACKEND=gcs
GCS_BUCKET=your-pipeline-datalake

# ── GCP Service Account Key ───────────────────────────────────────────────────
# Absolute path on the GCE VM to the downloaded SA key JSON.
# Not needed if running on GCE/GKE with Workload Identity or default SA.
GCP_SA_KEY_PATH=/home/your-user/gcp-sa-key.json

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_WORKERS=2
SPARK_EXECUTOR_CORES=2
SPARK_EXECUTOR_MEMORY=4g
SPARK_MASTER_URL=spark://spark-master:7077

# Streaming checkpoints go to GCS so they survive container restarts.
CHECKPOINT_BASE=gs://your-pipeline-datalake/checkpoints

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_PARTITIONS=12
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PAYMENTS=payments.raw
# External IP of the GCE VM — used in KAFKA_ADVERTISED_LISTENERS.
# Find it with: gcloud compute instances describe <vm-name> --format='get(networkInterfaces[0].accessConfigs[0].natIP)'
GCE_EXTERNAL_IP=34.xx.xx.xx

# ── Pipeline Optimization Toggles ────────────────────────────────────────────
ENABLE_DELTA_OPTIMIZE=true
ENABLE_ZORDER=true
ENABLE_AQE=true
ENABLE_BROADCAST_JOINS=true
ENABLE_INCREMENTAL_GOLD=true

# ── Observability ─────────────────────────────────────────────────────────────
PROMETHEUS_ENDPOINT=http://prometheus:9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
# Change this to a strong password before deploying.
GRAFANA_ADMIN_PASSWORD=ChangeMe123!

# ── Load Testing ──────────────────────────────────────────────────────────────
LOAD_TEST_USERS=50
LOAD_TEST_SPAWN_RATE=10
PIPELINE_API_PORT=8000

# ── Data Retention ────────────────────────────────────────────────────────────
DELTA_VACUUM_RETENTION_HOURS=168
