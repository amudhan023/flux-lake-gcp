# Spark Configuration
SPARK_WORKERS=2
SPARK_EXECUTOR_CORES=2
SPARK_EXECUTOR_MEMORY=4g
SPARK_MASTER_URL=spark://spark-master:7077

# Kafka Configuration
KAFKA_PARTITIONS=12
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_PAYMENTS=payments.raw

# GCS Configuration
# Local dev: fake-gcs-server emulates GCS at GCS_EMULATOR_HOST (set automatically by docker-compose).
# Production: leave GCS_EMULATOR_HOST unset; use GCS_BUCKET pointing to your real GCS bucket.
STORAGE_BACKEND=gcs
GCS_BUCKET=data-lake
GCS_EMULATOR_HOST=fake-gcs-server:4443

# Pipeline Optimization Toggles
ENABLE_DELTA_OPTIMIZE=true
ENABLE_ZORDER=true
ENABLE_AQE=true
ENABLE_BROADCAST_JOINS=true
ENABLE_INCREMENTAL_GOLD=true

# Observability
PROMETHEUS_ENDPOINT=http://prometheus:9090
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Load Testing
LOAD_TEST_USERS=50
LOAD_TEST_SPAWN_RATE=10

# Pipeline API
PIPELINE_API_PORT=8000

# Data Retention
DELTA_VACUUM_RETENTION_HOURS=168
